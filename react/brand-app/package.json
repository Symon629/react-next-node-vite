{
    "name": "brand-app",
    "version": "0.1.0",
    "private": true,
    "description": "React + TypeScript + Webpack client with a Node BFF that injects window.MYBRANDS",
    "scripts": {
        "build:client": "webpack --config webpack.config.js --mode production",
        "dev:client": "webpack serve --config webpack.config.js --mode development",
        "build:server": "tsc -p tsconfig.server.json",
        "start:server": "node dist/server/index.js",
        "build": "npm run build:client && npm run build:server",
        "start": "npm run build && npm run start:server",
        "dev": "concurrently -n CLIENT,SERVER -c blue,green \"npm:dev:client\" \"ts-node-dev --respawn --transpile-only src/server/index.ts\""
    },
    "dependencies": {
        "express": "^4.19.2",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-redux": "^9.1.2",
        "redux": "^5.0.1",
        "react-n8n-lib": "file:../react-n8n-lib"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^20.12.7",
        "@types/react": "^18.2.79",
        "@types/react-dom": "^18.2.25",
        "concurrently": "^8.2.2",
        "css-loader": "^7.1.1",
        "html-webpack-plugin": "^5.6.0",
        "style-loader": "^4.0.0",
        "ts-loader": "^9.5.1",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.4.5",
        "webpack": "^5.91.0",
        "webpack-cli": "^5.1.4",
        "webpack-dev-server": "^5.0.4"
    }
}